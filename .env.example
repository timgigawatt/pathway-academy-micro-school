# Gigawatt CMS base URL (no trailing slash). Required for builds.
PAYLOAD_URL=https://gigawatt-cms--gigawatt-lab.us-central1.hosted.app

# Build from local fixture content instead of the CMS (design iteration before
# the tenant exists). Never set this on Netlify.
# MOCK_CONTENT=1

# --- scripts/seed-content.mjs + scripts/migrate-firebase.mjs only ---
# Tenant editor account provisioned by the Gigawatt admin.
CMS_URL=https://gigawatt-cms--gigawatt-lab.us-central1.hosted.app
CMS_EMAIL=
CMS_PASSWORD=
