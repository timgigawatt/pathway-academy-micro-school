---
/**
 * Renders a CMS media document. Remote (CMS/GCS) images go through
 * astro:assets so the deployed site serves optimized local copies; repo-local
 * fixture paths fall back to a plain <img>.
 *
 * Media docs normally carry width/height. When they don't, we probe the
 * remote file ourselves — and if that fails (bad metadata, odd encoding), we
 * degrade to a plain <img> with a build warning instead of failing the whole
 * deploy the way <Image inferSize> would.
 */
import { Image, inferRemoteSize } from 'astro:assets'
import { mediaUrl, type Media } from '../lib/payload'

interface Props {
  media: Media | null | undefined
  class?: string
  loading?: 'lazy' | 'eager'
}

const { media, class: className, loading = 'lazy' } = Astro.props
const src = mediaUrl(media)
const isRemote = src ? /^https?:\/\//.test(src) : false

let width = media?.width ?? null
let height = media?.height ?? null
if (src && isRemote && (!width || !height)) {
  try {
    ;({ width, height } = await inferRemoteSize(src))
  } catch {
    console.warn(`[CmsImage] could not determine dimensions for ${src} — serving unoptimized`)
  }
}
---

{
  src && isRemote && width && height ? (
    <Image src={src} alt={media?.alt ?? ''} width={width} height={height} class={className} loading={loading} />
  ) : src ? (
    <img src={src} alt={media?.alt ?? ''} class={className} loading={loading} />
  ) : null
}
