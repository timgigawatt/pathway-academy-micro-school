---
/**
 * Renders a CMS media document as a plain <img>.
 *
 * The CMS pre-generates responsive variants at upload (thumb/card/full webp),
 * so we hand-build a srcset and the site build does no image processing at
 * all. Docs without sizes (SVGs, originals ≤400px wide, uploads predating
 * imageSizes) serve the original file directly.
 *
 * Deliberately never uses astro:assets for CMS media: build-time fetch and
 * cache revalidation against the CMS stalls minutes per image (its file
 * endpoint redirects), and it re-encodes the whole gallery on cold CI caches.
 */
import { mediaSrcset, mediaUrl, type Media } from '../lib/payload'

interface Props {
  media: Media | null | undefined
  class?: string
  loading?: 'lazy' | 'eager'
  /** Rendered-width hint for the srcset; tune per layout slot. */
  sizes?: string
}

const { media, class: className, loading = 'lazy', sizes = '(min-width: 768px) 33vw, 100vw' } = Astro.props
const src = mediaUrl(media)
const srcset = mediaSrcset(media)
---

{
  src ? (
    <img
      src={src}
      srcset={srcset ?? undefined}
      sizes={srcset ? sizes : undefined}
      alt={media?.alt ?? ''}
      width={media?.width ?? undefined}
      height={media?.height ?? undefined}
      class={className}
      loading={loading}
      decoding="async"
    />
  ) : null
}
