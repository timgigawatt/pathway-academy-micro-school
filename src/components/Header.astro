---
import type { NavItem } from '../lib/payload'

interface Props {
  nav: NavItem[]
}

const { nav } = Astro.props
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href))
---

<header class="sticky top-0 z-40 border-b border-gray-100 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-3">
      <img src="/images/logo.png" alt="Pathway Academy" class="h-12 w-auto" />
      <span class="hidden text-sm font-semibold tracking-wide text-brand-600 sm:block">MICRO SCHOOL</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-4 py-2 text-base font-medium transition-colors hover:bg-gray-100',
              isActive(item.href) ? 'text-brand-700' : 'text-gray-900',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="ml-3 rounded-full bg-brand-600 px-4 py-2 text-base font-medium text-white transition-colors hover:bg-brand-700"
      >
        Get in Touch
      </a>
    </nav>

    <button
      id="menu-open"
      class="flex size-12 items-center justify-center rounded-lg hover:bg-black/5 lg:hidden"
      aria-label="Open main menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
        <path
          fill-rule="evenodd"
          d="M3 9a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 9Zm0 6.75a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="fixed inset-0 z-50 hidden lg:hidden">
    <div id="menu-backdrop" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm"></div>
    <div class="fixed inset-y-0 right-0 w-full max-w-sm bg-white px-6 py-6 shadow-lg">
      <div class="mb-8 flex items-center justify-between">
        <img src="/images/logo.png" alt="Pathway Academy" class="h-12 w-auto" />
        <button id="menu-close" class="rounded-lg p-2 hover:bg-gray-100" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <nav class="flex flex-col gap-2" aria-label="Mobile">
        {
          nav.map((item) => (
            <a href={item.href} class="rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100">
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="mt-8 border-t border-gray-200 pt-8">
        <a
          href="/contact"
          class="flex items-center justify-center rounded-lg bg-brand-600 px-4 py-2 font-medium text-white hover:bg-brand-700"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menu = document.getElementById('mobile-menu')
  const openBtn = document.getElementById('menu-open')
  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open)
    document.body.style.overflow = open ? 'hidden' : ''
    openBtn?.setAttribute('aria-expanded', String(open))
  }
  openBtn?.addEventListener('click', () => setOpen(true))
  document.getElementById('menu-close')?.addEventListener('click', () => setOpen(false))
  document.getElementById('menu-backdrop')?.addEventListener('click', () => setOpen(false))
</script>
