---
import type { Footer as FooterData } from '../lib/payload'

interface Props {
  footer: FooterData | null
}

const { footer } = Astro.props
const contact = footer?.contact
---

<footer class="bg-slate-100 py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
      {
        contact && (
          <div>
            <h3 class="mb-4 text-xl font-medium">Contact</h3>
            <div class="space-y-2 text-gray-700">
              {contact.phone && (
                <p>
                  <a href={`tel:${contact.phone.replace(/[^+\d]/g, '')}`} class="hover:text-brand-700">
                    {contact.phone}
                  </a>
                </p>
              )}
              {contact.address && contact.address.split('\n').map((line) => <p>{line}</p>)}
              {contact.email && (
                <p>
                  <a href={`mailto:${contact.email}`} class="hover:text-brand-700">
                    {contact.email}
                  </a>
                </p>
              )}
            </div>
          </div>
        )
      }

      {
        footer?.social?.length ? (
          <div>
            <h3 class="mb-4 text-xl font-medium">Follow Us</h3>
            <div class="flex gap-4">
              {footer.social.map((s) => (
                <a href={s.href} class="text-gray-700 hover:text-brand-700" rel="noopener">
                  {s.platform}
                </a>
              ))}
            </div>
          </div>
        ) : null
      }

      {
        footer?.columns?.map((col) => (
          <div>
            {col.heading && <h3 class="mb-4 text-xl font-medium">{col.heading}</h3>}
            <ul class="space-y-2">
              {col.links?.map((link) => (
                <li>
                  <a href={link.href} class="text-gray-700 hover:text-brand-700">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 border-t border-gray-300 pt-6 text-center text-gray-600">
      <p>{footer?.copyright ?? '© Pathway Academy. All Rights Reserved.'}</p>
    </div>
  </div>
</footer>
