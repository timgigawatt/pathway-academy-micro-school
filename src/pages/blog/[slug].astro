---
import CmsImage from '../../components/CmsImage.astro'
import Base from '../../layouts/Base.astro'
import { getPosts, type Post } from '../../lib/payload'

export async function getStaticPaths() {
  const posts = await getPosts()
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }))
}

interface Props {
  post: Post
}

const { post } = Astro.props
const published = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null
---

<Base title={post.title} description={post.excerpt ?? undefined}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/blog" class="text-sm font-medium text-brand-600 hover:text-brand-800">← Back to blog</a>
    <h1 class="mt-6 text-4xl font-medium text-gray-900">{post.title}</h1>
    {published && <p class="mt-3 text-gray-500">{published}</p>}
    {
      post.coverImage && (
        <div class="mt-8 overflow-hidden rounded-2xl">
          <CmsImage media={post.coverImage} class="w-full" loading="eager" />
        </div>
      )
    }
    <div class="post-body mt-10" set:html={post.contentHtml ?? ''} />
  </article>
</Base>
