---
import BlockRenderer from '../components/BlockRenderer.astro'
import ContactForm from '../components/ContactForm.astro'
import Base from '../layouts/Base.astro'
import { getPages, type Page } from '../lib/payload'

export async function getStaticPaths() {
  const pages = await getPages()
  // The homepage is code-owned (src/pages/index.astro, from the Home.dc.html
  // design); a CMS "home" page, if one still exists, is ignored.
  return pages
    .filter((page) => page.slug !== 'home')
    .map((page) => ({
      params: { slug: page.slug },
      props: { page },
    }))
}

interface Props {
  page: Page
}

const { page } = Astro.props
---

<Base title={page.title}>
  <BlockRenderer blocks={page.layout} />
  {page.slug === 'contact' && <ContactForm />}
</Base>
