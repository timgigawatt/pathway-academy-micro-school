---
import Base from '../layouts/Base.astro'
---

<Base title="Thank You">
  <div class="mx-auto max-w-2xl px-6 py-32 text-center">
    <h1 class="text-4xl font-medium text-gray-900">Thank you!</h1>
    <p class="mt-6 text-lg text-gray-600">
      Your message has been sent. We'll get back to you as soon as we can.
    </p>
    <a
      href="/"
      class="mt-10 inline-flex items-center justify-center rounded-full bg-brand-600 px-6 py-2.5 font-medium text-white hover:bg-brand-700"
    >
      Back to Home
    </a>
  </div>
</Base>
